# Dial Up Deploy — Development Caddyfile example
#
# Copy this file to `Caddyfile` and edit the paths/domain for your local dev
# environment, or let `deploy setup` generate one for you. The generated file
# is gitignored.
#
# Replace <PROJECT_DIR> with your project directory and <DEV_DOMAIN> with your
# local dev domain (e.g. dev.deploy).

{
  # Use project directory for storage
  storage file_system {
    root <PROJECT_DIR>/.deploy/caddy/data
  }

  # Use local certificates for development
  local_certs

  # Enable debug logging in development
  debug

  # Log configuration
  log {
    output file <PROJECT_DIR>/.deploy/caddy/access.log
    format json
  }
}

# Root domain configuration
<DEV_DOMAIN> {
  encode {
    gzip 6
    zstd
  }

  header {
    -Server
    X-Content-Type-Options nosniff
    X-Frame-Options DENY
    X-XSS-Protection "1; mode=block"
    Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  }

  reverse_proxy localhost:3000 {
    health_uri /health
    health_interval 30s
    health_timeout 5s
    flush_interval -1
  }
}

# Wildcard subdomain configuration
*.<DEV_DOMAIN> {
  reverse_proxy localhost:3000 {
    header_up Host {host}
    header_up X-Real-IP {remote}
    header_up X-Forwarded-For {remote}
    header_up X-Forwarded-Proto {scheme}
  }
}
